# Resend API Key for sending emails
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Email recipient for notifications (contact & demo forms)
# The email address where form submissions will be sent
EMAIL_RECIPIENT=contact@senury.com

# Optional: BCC address for archiving all form submissions
# EMAIL_BCC=archive@senury.com

# Demo request feature flag
# Set to "true" to enable the demo request form, "false" to show coming soon message
ENABLE_DEMO_REQUEST=false
